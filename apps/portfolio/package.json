{
  "name": "@ish/portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:og-diagrams": "tsx scripts/generate-og-diagrams.tsx",
    "aot:compile": "node scripts/aot-prebuild.mjs",
    "dev": "pnpm generate:og-diagrams && vite dev",
    "build": "pnpm generate:og-diagrams && vite build",
    "build:aot": "pnpm aot:compile && ENABLE_AOT=1 pnpm build",
    "build:aot-nm": "AOT_NODE_MODULES=1 pnpm aot:compile && ENABLE_AOT=1 pnpm build",
    "build:vercel": "bash scripts/vercel-build.sh",
    "preview": "vite preview",
    "format": "oxfmt",
    "format-check": "oxfmt --check",
    "lint": "oxlint --max-warnings=0 --type-aware --type-check",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "sync-to-devto": "pnpm dlx vite-node --config scripts/vite.scripts.config.ts scripts/sync-to-devto.ts",
    "sync-to-hashnode": "pnpm dlx vite-node --config scripts/vite.scripts.config.ts scripts/sync-to-hashnode.ts"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/syne": "^5.2.7",
    "@fontsource/noto-sans": "^5.2.10",
    "@fontsource/noto-sans-mono": "^5.2.10",
    "@i2-labs/compiler": "workspace:*",
    "@iframe-resizer/child": "^5.5.9",
    "@iframe-resizer/react": "^5.5.9",
    "@ish/design-overlay": "workspace:*",
    "@ish/sandbox": "workspace:*",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.162.8",
    "@tanstack/react-router-ssr-query": "^1.166.7",
    "@tanstack/react-start": "^1.162.8",
    "@types/turndown": "^5.0.6",
    "@vercel/analytics": "^1.4.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^1.3.1",
    "better-auth": "^1.4.20",
    "class-variance-authority": "^0.7.1",
    "drizzle-orm": "^0.45.1",
    "feed": "^5.2.0",
    "nitro": "3.0.1-alpha.2",
    "pg": "^8.19.0",
    "posthog-js": "^1.359.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "shiki": "^4.0.1",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "tw-animate-css": "^1.4.0",
    "view-transitions-polyfill": "^1.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@pnpm/find-workspace-packages": "^6.0.9",
    "@scelar/nodepod": "^1.0.2",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^5.1.1",
    "@whatwg-node/server": "^0.10.18",
    "auth": "^1.5.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tailwindcss": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vite": "^7.2.4",
    "vite-tsconfig-paths": "^6.1.0"
  },
  "dependenciesMeta": {
    "@ish/design-overlay": {
      "injected": true
    },
    "@ish/sandbox": {
      "injected": true
    }
  },
  "packageManager": "pnpm@10.30.3"
}

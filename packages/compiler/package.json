{
  "name": "@i2-labs/compiler",
  "description": "JavaScript ahead-of-time compiler",
  "keywords": [],
  "author": "Ish Chhabra",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "dist/cli.js",
  "exports": {
    ".": "./dist/cli.js",
    "./compile": "./dist/compile.js"
  },
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "postbuild": "node scripts/clean-sync-targets.mjs && pnpm-sync copy && echo 'Build complete'",
    "prepare": "pnpm sync:prepare:portfolio && pnpm build",
    "test": "vitest run",
    "test:update": "UPDATE_FIXTURES=1 vitest run",
    "lint": "oxlint --max-warnings=0 --type-aware --type-check",
    "format": "oxfmt",
    "format-check": "oxfmt --check",
    "type-check": "tsc --noEmit",
    "sync:prepare:portfolio": "pnpm-sync prepare -l ../../apps/portfolio/pnpm-lock.yaml -s ../../apps/portfolio/node_modules/.pnpm"
  },
  "dependencies": {
    "@babel/generator": "^7.28.3",
    "@babel/helper-validator-identifier": "^7.28.5",
    "@babel/types": "^7.28.4",
    "@oxc-project/types": "^0.123.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "eslint-visitor-keys": "^4.2.1",
    "figures": "^6.1.0",
    "glob": "^13.0.6",
    "lodash-es": "^4.17.21",
    "log-update": "^6.1.0",
    "ora": "^8.2.0",
    "oxc-parser": "^0.123.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__helper-validator-identifier": "^7.15.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "rollup": "^4.52.5",
    "rollup-plugin-node-externals": "^8.1.2",
    "test262-stream": "^1.4.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}

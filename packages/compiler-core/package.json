{
  "name": "@i2-labs/compiler",
  "description": "JavaScript ahead-of-time compiler",
  "keywords": [],
  "author": "Ish Chhabra",
  "type": "module",
  "main": "./dist/compile/index.js",
  "exports": {
    ".": {
      "types": "./dist/compile/index.d.ts",
      "default": "./dist/compile/index.js"
    },
    "./compile": {
      "types": "./dist/compile/index.d.ts",
      "default": "./dist/compile/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "default": "./dist/vite/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly && rolldown -c",
    "postbuild": "pnpm-sync copy && echo 'Build complete'",
    "prepare": "pnpm sync:prepare:portfolio && pnpm build",
    "format": "oxfmt -c oxfmt.config.mjs",
    "format-check": "oxfmt --check -c oxfmt.config.mjs",
    "lint": "oxlint src --ignore-pattern '**/*.test.ts' --ignore-pattern '**/testing.ts' --max-warnings=0 --type-aware --type-check",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:test262": "node scripts/test262/run.mjs",
    "sync:prepare:portfolio": "pnpm-sync prepare -l ../../apps/portfolio/pnpm-lock.yaml -s ../../apps/portfolio/node_modules/.pnpm"
  },
  "dependencies": {
    "esrap": "^2.2.5",
    "oxc-parser": "^0.123.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "pnpm-sync": "^0.3.3",
    "rolldown": "1.0.0-rc.18",
    "typescript": "catalog:",
    "vite": "^7.3.2",
    "vitest": "^4.1.5",
    "yaml": "2.9.0"
  },
  "peerDependencies": {
    "vite": "^7.0.0 || ^8.0.0"
  }
}

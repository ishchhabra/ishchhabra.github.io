{
  "name": "@i2-labs/compiler-plugin-ecmascript",
  "description": "ECMAScript semantic plugin for the I2 Labs compiler",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --sourceRoot \"$(pwd)/src\" && tsc-alias -p tsconfig.json",
    "build:watch": "tsc-watch -p tsconfig.json --sourceRoot \"$(pwd)/src\" --onSuccess \"pnpm postbuild\"",
    "postbuild": "tsc-alias -p tsconfig.json && pnpm-sync copy && echo 'Build complete'",
    "prepare": "pnpm sync:prepare:portfolio && pnpm build",
    "format": "oxfmt",
    "format-check": "oxfmt --check",
    "lint": "oxlint src --max-warnings=0 --type-aware --type-check",
    "type-check": "tsc --noEmit",
    "sync:prepare:portfolio": "pnpm-sync prepare -l ../../apps/portfolio/pnpm-lock.yaml -s ../../apps/portfolio/node_modules/.pnpm"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "pnpm-sync": "^0.3.3",
    "tsc-alias": "^1.8.16",
    "tsc-watch": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.30.3"
}

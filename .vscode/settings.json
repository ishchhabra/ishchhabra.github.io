{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "always"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "oxc.fmt.configPath": "oxfmt.config.mjs",
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "eslint.workingDirectories": [{ "mode": "auto" }]
}
